{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"console.log('\\n🛡️  Workflow StackNest : ticket Jira (En développement) → /TDD (Red → Green → Blue) → DoD complète (lint/typecheck/tests/doc tous verts) → commit STN-XX en français → PR. Règles non-négociables et DoD dans CLAUDE.md.\\n')\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/quality-check.cjs --mode=post-edit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/quality-check.cjs --mode=stop"
          }
        ]
      }
    ]
  }
}
