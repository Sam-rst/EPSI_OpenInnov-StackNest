# Environment
.env
.env.*
!.env.example

# SOPS / age — clés privées (filet de sécurité si quelqu'un les copie dans le repo).
# Emplacement standard des clés : ~/.sops/age/key.txt (hors repo par défaut).
.sops/
*.age
key.txt
# Fichiers secrets déchiffrés (toujours chiffrés via SOPS, ne jamais commit en clair).
secrets.*.env
!secrets.*.sops.env
!secrets.*.sops.yaml
!secrets.*.sops.json

# Dependencies
node_modules/
__pycache__/
*.pyc
.venv/

# Python tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# Logs
*.log

# Build
dist/
build/
*.egg-info/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Terraform
*.tfstate
*.tfstate.backup
.terraform/
*.tfvars
!*.tfvars.example
# Whitelist des tfvars d'environnement (pas de secrets ; secrets via SOPS — STN-31).
!infra/terraform/environments/*/*.tfvars

# Coverage
htmlcov/
.coverage
.coverage.*
coverage.xml
coverage/
lcov.info

# Docker
*.tar

# Claude Code
.claude/settings.local.json
