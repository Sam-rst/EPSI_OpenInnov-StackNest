# Variables d'environnement StackNest — copier en .env puis adapter.
# Utilisees par docker-compose.yml et les services qu'il orchestre.

# ---------- Worktrees multi-agents (STN-156) ----------
# Nom de projet Docker Compose. Défaut = stacknest (dépôt principal / slot 0).
# Dans un worktree, scripts/worktree.sh génère un .env avec un nom unique
# (stacknest-wt<slot>) + les 7 ports décalés de slot×100 pour isoler la stack.
# COMPOSE_PROJECT_NAME=stacknest

# ---------- General ----------
APP_ENV=dev
APP_VERSION=0.78.0
GIT_COMMIT=unknown
DEPLOYED_AT=1970-01-01T00:00:00Z

# ---------- PostgreSQL ----------
POSTGRES_DB=stacknest
POSTGRES_USER=stacknest
POSTGRES_PASSWORD=stacknest
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_PORT=6379

# ---------- API (FastAPI) ----------
API_PORT=8000
DATABASE_URL=postgresql+asyncpg://stacknest:stacknest@db:5432/stacknest
REDIS_URL=redis://redis:6379/0
SENTRY_DSN=

# ---------- Authentification / JWT (STN socle back) ----------
# Secret de signature des JWT (HS256). OBLIGATOIRE en preview/prod : injecte
# via SOPS par la CD. Le default applicatif est un secret de DEV non securise.
JWT_SECRET=dev-insecure-change-me
# Durees de vie des tokens (en secondes). Access court (15 min), refresh long (7 j).
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
# Exiger un email verifie a la connexion (false en MVP, true en preview/prod).
AUTH_REQUIRE_EMAIL_VERIFICATION=false
# Rate-limit des endpoints d'auth sensibles : max tentatives par fenetre glissante.
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
# Cookie HttpOnly portant le refresh token. secure=false uniquement en dev HTTP local.
REFRESH_COOKIE_NAME=stacknest_refresh
REFRESH_COOKIE_SAMESITE=strict
REFRESH_COOKIE_SECURE=true
# Origines autorisees par CORS (credentials). Format JSON. Vide = origine identique (Nginx).
CORS_ORIGINS=[]

# SMTP pour l'EmailSender (STN-34). Par defaut pointe sur MailHog en dev
# (profile smtp). STN-35 branchera les vraies credentials via SOPS pour
# preview/prod.
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_STARTTLS=false
SMTP_FROM_ADDRESS=noreply@stacknest.local

# ---------- Chat IA / LLM (fournisseur pluggable, cf. design Chat IA) ----------
# Fournisseur LLM : ollama (defaut, local, sans cle) | openai | anthropic.
LLM_PROVIDER=ollama
# Cle d'API du fournisseur. VIDE par defaut (Ollama n'en a pas besoin).
#   - Anthropic : cle 'sk-ant-...' -> https://console.anthropic.com > Settings > API keys > Create key.
#   - OpenAI    : cle 'sk-...'     -> https://platform.openai.com/api-keys.
# NE JAMAIS committer une vraie cle : ceci est l'exemple ; le vrai .env est gitignore.
# En preview/prod la cle est injectee via SOPS (pas de cle en clair dans le repo).
LLM_API_KEY=
# Modele selon le fournisseur :
#   - anthropic : claude-3-5-sonnet-latest (reco, tool-calling fiable) ou claude-3-5-haiku-latest (+ rapide/econome)
#   - openai    : gpt-4o-mini
#   - ollama    : llama3.1 ('docker compose --profile ollama up' + 'ollama pull llama3.1')
LLM_MODEL=llama3.1
# URL de base du fournisseur. Vide = URL par defaut de l'adaptateur
# (api.anthropic.com / api.openai.com / http://localhost:11434 pour Ollama).
LLM_BASE_URL=
# Timeout (secondes) des appels reseau au LLM.
LLM_TIMEOUT_SECONDS=60

# ---------- UI (Vite + Nginx) ----------
# Port expose par le reverse-proxy Nginx du container web (CA1 du ticket STN-11).
UI_PORT=8080
# Les VITE_* sont injectees au build Vite dans le conteneur ui.
VITE_API_URL=/api
VITE_ENVIRONMENT=dev
VITE_SENTRY_DSN=

# ---------- MailHog (optionnel — docker compose --profile smtp up) ----------
# Serveur SMTP local avec inbox web sur http://localhost:8025
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ---------- Ollama (optionnel — docker compose --profile ollama up) ----------
OLLAMA_PORT=11434
