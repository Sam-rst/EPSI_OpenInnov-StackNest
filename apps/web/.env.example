# URL de base de l'API. Relative (/api) par defaut : le front appelle /api/*,
# proxifie par Vite en dev (server.proxy -> VITE_API_PROXY_TARGET) et par Nginx
# en preview/prod. Garder relatif evite CORS et les soucis de prefixe passerelle.
VITE_API_URL=/api

# Environnement de deploiement (dev | test | preview | prod)
VITE_ENVIRONMENT=dev

# DSN Sentry — laisser vide pour desactiver le monitoring
VITE_SENTRY_DSN=
