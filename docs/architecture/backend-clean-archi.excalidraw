    },
    {
      "id": "tree-content",
      "type": "text",
      "x": 1020,
      "y": 125,
      "width": 440,
      "height": 520,
      "text": "api/app/catalog/\n│\n├── domain/\n│   ├── __init__.py\n│   ├── entities.py\n│   │   ├── Template (dataclass)\n│   │   ├── TemplateVersion (dataclass)\n│   │   └── TemplateParam (dataclass)\n│   ├── interfaces.py\n│   │   └── TemplateRepositoryInterface (ABC)\n│   │       ├── get_by_id(id) → Template\n│   │       ├── list_all(filters) → list[Template]\n│   │       ├── create(entity) → Template\n│   │       ├── update(entity) → Template\n│   │       └── delete(id) → None\n│   └── exceptions.py\n│       ├── TemplateNotFoundError\n│       └── TemplateAlreadyExistsError\n│\n├── application/\n│   ├── __init__.py\n│   ├── create_template.py\n│   │   └── CreateTemplateUseCase.execute(data)\n│   ├── get_template.py\n│   │   └── GetTemplateUseCase.execute(id)\n│   ├── list_templates.py\n│   │   └── ListTemplatesUseCase.execute(filters)\n│   ├── update_template.py\n│   └── delete_template.py\n│\n├── infrastructure/\n│   ├── __init__.py\n│   ├── models.py\n│   │   ├── TemplateModel (SQLAlchemy)\n│   │   └── TemplateVersionModel (SQLAlchemy)\n│   ├── repository.py\n│   │   └── TemplateRepository(Interface)\n│   └── mappers.py\n│       ├── to_entity(model) → Template\n│       └── to_model(entity) → TemplateModel\n│\n└── presentation/\n    ├── __init__.py\n    ├── router.py\n    │   ├── POST   /catalog/templates\n    │   ├── GET    /catalog/templates\n    │   ├── GET    /catalog/templates/{id}\n    │   ├── PUT    /catalog/templates/{id}\n    │   └── DELETE /catalog/templates/{id}\n    ├── schemas.py\n    │   ├── CreateTemplateRequest (Pydantic)\n    │   ├── UpdateTemplateRequest (Pydantic)\n    │   └── TemplateResponse (Pydantic)\n    └── dependencies.py\n        └── get_create_template_use_case()",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
