      "verticalAlign": "top",
      "containerId": null,
      "originalText": "     │                    │                  │                  │                  │                  │\n     │ POST /catalog/      │                  │                  │                  │                  │\n     │ templates           │                  │                  │                  │                  │\n     │ {name, desc, ...}   │                  │                  │                  │                  │\n     │───────────────────>│                  │                  │                  │                  │\n     │                    │ validate body     │                  │                  │                  │\n     │                    │─────────────────>│                  │                  │                  │\n     │                    │                  │ CreateTemplateReq │                  │                  │\n     │                    │                  │ (Pydantic)        │                  │                  │\n     │                    │<─────────────────│                  │                  │                  │\n     │                    │                  │                  │                  │                  │\n     │                    │ execute(data)     │                  │                  │                  │\n     │                    │ via Depends()     │                  │                  │                  │\n     │                    │────────────────────────────────────>│                  │                  │\n     │                    │                  │                  │ create entity     │                  │\n     │                    │                  │                  │ (domain)          │                  │\n     │                    │                  │                  │                  │                  │\n     │                    │                  │                  │ repo.create()     │                  │\n     │                    │                  │                  │─────────────────>│                  │\n     │                    │                  │                  │                  │ mapper: entity    │\n     │                    │                  │                  │                  │ → SQLAlchemy      │\n     │                    │                  │                  │                  │ model             │\n     │                    │                  │                  │                  │ INSERT INTO...    │\n     │                    │                  │                  │                  │─────────────────>│\n     │                    │                  │                  │                  │<─────────────────│\n     │                    │                  │                  │                  │ mapper: model     │\n     │                    │                  │                  │                  │ → entity          │\n     │                    │                  │                  │<─────────────────│                  │\n     │                    │                  │                  │                  │                  │\n     │                    │                  │                  │ return entity     │                  │\n     │                    │<────────────────────────────────────│                  │                  │\n     │                    │                  │                  │                  │                  │\n     │                    │ entity → schema   │                  │                  │                  │\n     │                    │ (TemplateResponse) │                  │                  │                  │\n     │ 201 Created        │                  │                  │                  │                  │\n     │ {id, name, ...}    │                  │                  │                  │                  │\n     │<───────────────────│                  │                  │                  │                  │\n     │                    │                  │                  │                  │                  │",
      "autoResize": true,
