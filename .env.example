# Variables d'environnement StackNest — copier en .env puis adapter.
# Utilisees par docker-compose.yml et les services qu'il orchestre.

# ---------- General ----------
APP_ENV=dev
APP_VERSION=0.0.0-dev
GIT_COMMIT=unknown
DEPLOYED_AT=1970-01-01T00:00:00Z

# ---------- PostgreSQL ----------
POSTGRES_DB=stacknest
POSTGRES_USER=stacknest
POSTGRES_PASSWORD=stacknest
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_PORT=6379

# ---------- API (FastAPI) ----------
API_PORT=8000
DATABASE_URL=postgresql+asyncpg://stacknest:stacknest@db:5432/stacknest
REDIS_URL=redis://redis:6379/0
SENTRY_DSN=

# SMTP pour l'EmailSender (STN-34). Par defaut pointe sur MailHog en dev
# (profile smtp). STN-35 branchera les vraies credentials via SOPS pour
# preview/prod.
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_STARTTLS=false
SMTP_FROM_ADDRESS=noreply@stacknest.local

# ---------- UI (Vite + Nginx) ----------
# Port expose par le reverse-proxy Nginx du container web (CA1 du ticket STN-11).
UI_PORT=8080
# Les VITE_* sont injectees au build Vite dans le conteneur ui.
VITE_API_URL=/api
VITE_ENVIRONMENT=dev
VITE_SENTRY_DSN=

# ---------- MailHog (optionnel — docker compose --profile smtp up) ----------
# Serveur SMTP local avec inbox web sur http://localhost:8025
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ---------- Ollama (optionnel — docker compose --profile ollama up) ----------
OLLAMA_PORT=11434
